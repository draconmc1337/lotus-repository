pkgname="bc"
pkgver="7.0.3"
pkgrel="1"
depends=("readline")
makedepends=()
source="https://mirror-hk.koddos.net/lfs/lfs-packages/12.4/bc-${pkgver}.tar.xz"
sha256sums="SKIP"
build() {
    tar -xf bc-${pkgver}.tar.xz
    cd bc-${pkgver}
    CC=gcc ./configure --prefix=/usr -G -O3 -r
    make -j$(nproc)
}
check() { cd bc-${pkgver}; make test; }
package() {
    cd bc-${pkgver}
    make DESTDIR="${pkgdir}" install
}
uninstall() { rm -f /usr/bin/bc /usr/bin/dc; }
