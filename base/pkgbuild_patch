pkgname="patch"
pkgver="2.8"
pkgrel="1"
depends=()
makedepends=()
source="https://mirror-hk.koddos.net/lfs/lfs-packages/12.4/patch-${pkgver}.tar.xz"
md5sums="149327a021d41c8f88d034eab41c039f"
build() {
    tar -xf patch-${pkgver}.tar.xz
    cd patch-${pkgver}
    ./configure --prefix=/usr
    make -j$(nproc)
}
check() { cd patch-${pkgver}; make check; }
package() {
    cd patch-${pkgver}
    make DESTDIR="${pkgdir}" install
}
uninstall() { rm -f /usr/bin/patch; }
