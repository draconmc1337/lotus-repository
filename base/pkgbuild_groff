pkgname="groff"
pkgver="1.23.0"
pkgrel="1"
depends=("perl")
makedepends=()
source="https://mirror-hk.koddos.net/lfs/lfs-packages/12.4/groff-${pkgver}.tar.gz"
sha256sums="SKIP"
build() {
    tar -xf groff-${pkgver}.tar.gz
    cd groff-${pkgver}
    PAGE=letter ./configure --prefix=/usr
    make -j$(nproc)
}
check() { : ; }
package() {
    cd groff-${pkgver}
    make DESTDIR="${pkgdir}" install
}
uninstall() { rm -f /usr/bin/groff /usr/bin/troff /usr/bin/nroff; }
