pkgname="man-pages"
pkgver="6.15"
pkgrel="1"
depends=()
recommends=()
makedepends=()
source="https://mirror-hk.koddos.net/lfs/lfs-packages/12.4/man-pages-${pkgver}.tar.xz"
sha256sums="SKIP"
build() {
    tar -xf man-pages-${pkgver}.tar.xz
    cd man-pages-${pkgver}
    rm -v man3/crypt*
}
check() { : ; }
package() {
    cd man-pages-${pkgver}
    make -R GIT=false prefix=/usr DESTDIR="${pkgdir}" install
}
uninstall() {
    rm -rf /usr/share/man
}
