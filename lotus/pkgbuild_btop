pkgname="btop"
pkgver="1.4.6"
pkgrel="1"
depends=("gcc" "glibc")
recommends=()
makedepends=()

source="https://github.com/aristocratos/btop/archive/refs/tags/v1.4.6.tar.gz"

build() {
    tar -xf btop-1.4.6.tar.xz
    cd btop-1.4.6
    make
}

package() {
    cd btop-1.4.6
    make DESTDIR="${pkgdir}" install
}

uninstall() {
    rm -f /usr/bin/btop
    rm -rf /usr/share/btop
}
